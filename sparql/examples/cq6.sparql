PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX planning-ontology: <https://purl.org/ai4s/ontology/planning#>
PREFIX tp-ont: <https://w3id.org/tp-ont/ontology#>
SELECT DISTINCT ?fluent WHERE {
  ?predicate rdf:type tp-ont:Predicate ;
            tp-ont:hasFluent ?fluent ;
            ?property ?arg .
  ?property rdfs:subPropertyOf tp-ont:hasArg2 .
}
GROUP BY ?fluent