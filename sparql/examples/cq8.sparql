PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX planning-ontology: <https://purl.org/ai4s/ontology/planning#>
PREFIX tp-ont: <https://w3id.org/tp-ont/ontology#>
SELECT ?type (COUNT(?domain) AS ?frequency) WHERE {
  ?domain rdf:type planning-ontology:PlanningDomain ;
     tp-ont:hasType ?type.
  ?type rdfs:subClassOf+ tp-ont:Vehicle.
}
GROUP BY ?type
ORDER BY DESC(?frequency)
LIMIT 1